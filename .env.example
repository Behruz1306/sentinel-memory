# Sentinel config — copy to .env and fill what you have.
# Everything is OPTIONAL: with no keys, the engine runs in deterministic
# (rule-based) mode so the demo never hard-fails.

# LLM for trust reasoning + social-engineering detection
OPENAI_API_KEY=
SENTINEL_LLM_MODEL=gpt-4o

# Voice agent (LiveKit) — only needed for the live phone-call demo
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=
