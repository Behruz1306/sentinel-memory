# Sentinel Memory — copy to .env and fill what you have.
# EVERYTHING is optional: with no keys the engine runs in deterministic mode and
# logs breaches locally, so the demo never hard-fails.

# ── LLM ensemble (social-engineering reasoning) ─────────────────────────────
# Threat analysis runs a CONSENSUS of independent analysts (defense in depth):
# to slip an attack past the firewall an adversary must fool every model at once.
# csv, queried concurrently. Recommended: minimax,qwen
SENTINEL_LLM_PROVIDERS=minimax,qwen   # openai | minimax | qwen (any subset)
# OpenAI:
OPENAI_API_KEY=
# MiniMax (OpenAI-compatible: base_url https://api.minimax.io/v1, model MiniMax-M3):
MINIMAX_API_KEY=
# Alibaba Cloud Qwen (DashScope / Model Studio, OpenAI-compatible, intl endpoint):
QWEN_API_KEY=
# Per-provider model overrides (ensemble mode):
# SENTINEL_MODEL_MINIMAX=MiniMax-M3
# SENTINEL_MODEL_QWEN=qwen-plus        # or qwen-max | qwen-turbo
# Back-compat single-provider mode (used only if PROVIDERS above is empty):
# SENTINEL_LLM_PROVIDER=openai
# SENTINEL_LLM_API_KEY=                # any OpenAI-compatible gateway
# SENTINEL_LLM_BASE_URL=
# SENTINEL_LLM_MODEL=

# ── Moss (real-time semantic retrieval — Sentinel's retrieval backend) ──────
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=sentinel_knowledge
MOSS_MODEL_ID=moss-minilm

# ── AWS CloudWatch (breach logging) ─────────────────────────────────────────
# If boto3 + creds present, RED ALERT breaches go to CloudWatch Logs;
# otherwise they fall back to ./security_events.jsonl + stderr.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SENTINEL_LOG_GROUP=/sentinel/security
# SENTINEL_CLOUDWATCH=0    # force-disable CloudWatch

# ── Unsiloed (PDF/DOCX → knowledge chunks in Workspace) ───────────────────
UNSILOED_API_KEY=

# ── Twilio (real PSTN calls through Sentinel Workspace) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Public URL Twilio webhooks hit (Render sets RENDER_EXTERNAL_URL automatically):
SENTINEL_PUBLIC_URL=
# SQLite path for sessions / turns / activity feed (default: data/sentinel.db):
# SENTINEL_DB_PATH=

# ── Supabase (persistent storage — survives Render redeploys) ───────────────
# Create project at supabase.com, run supabase/schema.sql, then:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# See SUPABASE_SETUP.md

# ── LiveKit voice transport (live voice demo) ───────────────────────────────
# STT/LLM/TTS run through LiveKit Inference (billed to LiveKit credits) — no
# OpenAI / Deepgram / Cartesia keys needed.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
